<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:layoutDirection="locale">

    <!-- Single Toolbar with Icons -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:title="@string/app_name"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="end"
            android:paddingEnd="8dp">

            <Button
                android:id="@+id/btnLanguage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EN"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/language"
                android:textAllCaps="false" />

            <ImageButton
                android:id="@+id/btnTheme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_dark_mode"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/theme"
                android:padding="8dp" />

            <ImageButton
                android:id="@+id/btnAbout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_info"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/about"
                android:padding="8dp" />

            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_share"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/share_app"
                android:padding="8dp" />

            <ImageButton
                android:id="@+id/btnScheduledJobs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_schedule"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/scheduled_jobs_title"
                android:visibility="gone"
                android:padding="8dp" />

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <!-- Main Content Area -->
    <LinearLayout
        android:id="@+id/layoutMainContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="?attr/colorSurface"
        android:elevation="8dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Phone Number Input Section -->
        <LinearLayout
            android:id="@+id/layoutPhoneSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/edtPhone"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/phone_hint"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:minLines="1"
                    android:maxLines="5"
                    android:scrollbars="vertical"
                    android:gravity="top|start"
                    android:textDirection="locale"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnContacts" />

                <Button
                    android:id="@+id/btnContacts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contacts"
                    android:minWidth="0dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/edtPhone"
                    app:layout_constraintBottom_toBottomOf="@id/edtPhone" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/txtPhoneHelper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/phone_hint_helper"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.6"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp" />
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <Button
                    android:id="@+id/btnSim"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sim_default"
                    android:minWidth="0dp"
                    android:maxLines="1"
                    android:minLines="1"
                    android:includeFontPadding="false"
                    android:textAllCaps="false"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="10sp"
                    app:autoSizeMaxTextSize="14sp"
                    app:autoSizeStepGranularity="1sp"
                    android:layout_marginEnd="4dp" />
                
                <Button
                    android:id="@+id/btnGroups"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/groups"
                    android:minWidth="0dp"
                    android:textAllCaps="false"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />
                
                <Button
                    android:id="@+id/btnSchedule"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/schedule"
                    android:minWidth="0dp"
                    android:textAllCaps="false"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Message Input Section -->
        <LinearLayout
            android:id="@+id/layoutMessageSection"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <!-- Message and Paste Button Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:minHeight="200dp">

                <EditText
                    android:id="@+id/edtMessage"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="9"
                    android:hint="@string/message_hint"
                    android:inputType="textMultiLine"
                    android:gravity="top|start"
                    android:textDirection="locale"
                    android:scrollbars="vertical"
                    android:padding="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageButton
                        android:id="@+id/btnPreparedMessages"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="44dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_prepared_messages"
                        android:background="@drawable/ripple_paste_button"
                        android:contentDescription="@string/prepared_messages"
                        android:scaleType="centerInside" />

                    <ImageButton
                        android:id="@+id/btnPaste"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:src="@drawable/ic_paste"
                        android:background="@drawable/ripple_paste_button"
                        android:contentDescription="@string/paste"
                        android:scaleType="centerInside"
                        android:padding="8dp"
                        android:clipToPadding="true"
                        android:outlineProvider="bounds" />

                </LinearLayout>

            </LinearLayout>

            <!-- Segment Counter and Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/txtSegment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/segments_count_zero"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.7"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/txtScheduledTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="12sp"
                    android:textColor="?attr/colorPrimary"
                    android:visibility="gone"
                    tools:text="Scheduled for 2026/01/01 12:00"
                    tools:visibility="visible" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:textColor="?attr/colorPrimary"
                        android:maxLines="1"
                        android:ellipsize="end"
                        tools:text="Status: Ready" />

                    <ProgressBar
                        android:id="@+id/progressSending"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="8dp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Send Button Section -->
        <Button
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="@string/send"
            android:enabled="true" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
