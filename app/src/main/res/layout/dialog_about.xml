<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="500dp"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="start">

        <TextView
            android:id="@+id/txtAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="center_horizontal"
            tools:text="Long SMS Sender" />

        <TextView
            android:id="@+id/txtVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.7"
            android:layout_marginBottom="24dp"
            android:layout_gravity="center_horizontal"
            tools:text="Version: 1.0.0" />

        <TextView
            android:id="@+id/txtAboutTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="12dp"
            tools:text="About This App" />

        <TextView
            android:id="@+id/txtAboutDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.8"
            android:lineSpacingExtra="4dp"
            android:gravity="start"
            android:layout_marginBottom="16dp"
            tools:text="This application is an open-source project..." />

        <TextView
            android:id="@+id/txtDeveloper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            tools:text="Developer" />

        <TextView
            android:id="@+id/txtDeveloperName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="?attr/colorPrimary"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            tools:text="Mostafa Afrouzi" />

        <TextView
            android:id="@+id/txtDeveloperInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.8"
            android:lineSpacingExtra="4dp"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            tools:text="Web &amp; App Design/Development, SEO &amp; Digital Marketing" />

        <TextView
            android:id="@+id/txtDeveloperDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.7"
            android:lineSpacingExtra="4dp"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            tools:text="I\'m Mostafa Afrouzi, a web and app designer..." />

        <!-- Links Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <!-- Website Link -->
            <Button
                android:id="@+id/btnWebsite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="afrouzi.ir"
                android:drawableLeft="@drawable/ic_website"
                android:drawableStart="@drawable/ic_website"
                android:drawablePadding="8dp"
                android:gravity="center"
                android:textAllCaps="false"
                android:singleLine="true"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_marginBottom="8dp" />

            <!-- GitHub Link -->
            <Button
                android:id="@+id/btnGitHub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="github.com/mostafaafrouzi"
                android:drawableLeft="@drawable/ic_github"
                android:drawableStart="@drawable/ic_github"
                android:drawablePadding="8dp"
                android:gravity="center"
                android:textAllCaps="false"
                android:singleLine="true"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_marginBottom="8dp" />

            <!-- LinkedIn Link -->
            <Button
                android:id="@+id/btnLinkedIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="linkedin.com/in/mostafaafrouzi"
                android:drawableLeft="@drawable/ic_linkedin"
                android:drawableStart="@drawable/ic_linkedin"
                android:drawablePadding="8dp"
                android:gravity="center"
                android:textAllCaps="false"
                android:singleLine="true"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtOpenSource"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.7"
            android:lineSpacingExtra="4dp"
            android:gravity="start"
            android:layout_marginTop="8dp"
            tools:text="This project is released as open source..." />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
